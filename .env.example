# JobPilot AI - Environment Configuration

# Application
APP_NAME=JobPilot AI
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://jobpilot:jobpilot_secret@localhost:5433/jobpilot_ai

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Qdrant Vector Memory
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=jobpilot_ai

# LLM provider: openai for proposals; ollama for filter/score/chat/learning
LLM_PROVIDER=openai
LLM_SIMPLE_PROVIDER=ollama
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3
# Ollama Cloud — https://github.com/ollama/ollama-python
# Ключ: https://ollama.com/settings/keys
# Список моделей: curl -H "Authorization: Bearer $OLLAMA_API_KEY" https://ollama.com/api/tags
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=minimax-m2.5
OLLAMA_TIMEOUT_SECONDS=120
# Прокси для Ollama Cloud (если пусто — используется OPENAI_PROXY_LIST)
# OLLAMA_PROXY_LIST=/app/proxy-lists/proxies_poland.txt
# Proxy for OpenAI (Poland) and Telegram (Belarus) — paths inside Docker container
OPENAI_PROXY_LIST=/app/proxy-lists/proxies_poland.txt
TELEGRAM_PROXY_LIST=/app/proxy-lists/proxies_belarus.txt
PROXY_ROTATE=true
PROXY_ROTATE_MODE=sequential
PROXY_MAX_ATTEMPTS=5
PROXY_STATE_DIR=/app/data
# Optional single proxy override for all services:
# PROXY=http://user:pass@host:port
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Cursor SDK (https://cursor.com/docs/sdk/python) — use composer-2.5, not *-fast
CURSOR_API_KEY=your-cursor-api-key
CURSOR_MODEL=composer-2.5
CURSOR_WORKSPACE=.

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id

# Developer Profile (used by agents)
DEVELOPER_NAME=Your Name
DEVELOPER_SKILLS=Python,FastAPI,React,PostgreSQL,Docker,AI/ML
DEVELOPER_HOURLY_RATE=50
DEVELOPER_BIO=Senior full-stack developer specializing in AI systems and automation.
# Portfolio for Kwork offers (one project per line: name | stack | description or link)
DEVELOPER_PORTFOLIO="JobPilot AI | Python, FastAPI, Celery, LangGraph, Playwright, PostgreSQL, Qdrant, Telegram | AI freelance automation: Kwork scraping, proposal generation, Telegram approval
Corporate web portal | Laravel, Vue 3, Keycloak, PostgreSQL, Redis | internal portal with SSO, roles, REST API (NDA, demo on request)
Order service with personal accounts | Django, React, Celery, Docker | client dashboard, admin, REST API integrations (NDA)
Business Telegram bot | Python, aiogram, FastAPI, PostgreSQL | notifications, dialog flows, external API integration
Data parser and integrations | Python, Playwright, FastAPI, Redis | web scraping, task queues, API export"
DEVELOPER_EXCLUDED_SKILLS=n8n,Make.com,Zapier

# Scraping
SCRAPE_INTERVAL_MINUTES=30
ENABLED_SCRAPERS=generic,kwork
GENERIC_SCRAPER_URL=https://example-freelance.com/jobs
GENERIC_SCRAPER_SELECTORS={"job_card":"article.job","title":"h2.title","description":".description","budget":".budget","skills":".skills li","deadline":".deadline","client":".client-name","link":"a.apply"}

# Kwork (optional credentials)
KWORK_EMAIL=
KWORK_PASSWORD=
KWORK_CATEGORY_URL=https://kwork.ru/projects?fc=11&a=1
KWORK_MAX_PAGES=10
KWORK_SCRAPE_LOGIN=false
# Optional: path to Playwright storage state JSON exported after manual Kwork login
KWORK_STORAGE_STATE=
# Bid % below buyer desired budget (default 15 — competitive for new sellers)
KWORK_OFFER_DISCOUNT_PERCENT=15
MIN_SCORE_THRESHOLD=35

# Scoring weights (JSON, adjusted by LearningAgent)
SCORING_WEIGHTS={"skill_match":0.30,"budget":0.20,"complexity":0.15,"client_quality":0.20,"competition":0.15}
